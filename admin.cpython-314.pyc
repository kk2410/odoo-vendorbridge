from django.urls import path
from . import views

app_name = 'quotations'

urlpatterns = [
    path('submit/<int:rfq_id>/', views.submit_quotation, name='submit_quotation'),
    path('<int:pk>/edit/', views.edit_quotation, name='edit_quotation'),
    path('<int:pk>/', views.quotation_detail, name='quotation_detail'),
    path('compare/<int:rfq_id>/', views.compare_quotations, name='compare_quotations'),
]
