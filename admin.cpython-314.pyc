from django.urls import path
from . import views

app_name = 'purchase_orders'

urlpatterns = [
    path('', views.po_list, name='po_list'),
    path('generate/<int:rfq_id>/', views.generate_purchase_order, name='generate_purchase_order'),
    path('<int:pk>/', views.po_detail, name='po_detail'),
    path('<int:pk>/accept/', views.accept_po, name='accept_po'),
]
