from django.db import models
from django.conf import settings

class Vendor(models.Model):
    CATEGORY_CHOICES = (
        ('it', 'IT & Software'),
        ('office', 'Office Supplies'),
        ('logistics', 'Logistics & Shipping'),
        ('services', 'Professional Services'),
        ('mfg', 'Manufacturing & Raw Materials'),
    )
    
    STATUS_CHOICES = (
        ('active', 'Active'),
        ('inactive', 'Inactive'),
    )

    user = models.OneToOneField(
        settings.AUTH_USER_MODEL, 
        on_delete=models.CASCADE, 
        related_name='vendor_profile',
        null=True, 
        blank=True
    )
    company_name = models.CharField(max_length=150, unique=True)
    category = models.CharField(max_length=20, choices=CATEGORY_CHOICES, default='office')
    gst_number = models.CharField(max_length=15, unique=True)
    contact_person = models.CharField(max_length=100)
    email = models.EmailField(unique=True)
    phone_number = models.CharField(max_length=15)
    address = models.TextField()
    rating = models.DecimalField(max_digits=3, decimal_places=2, default=5.00)  # scale 0.00 to 5.00
    status = models.CharField(max_length=10, choices=STATUS_CHOICES, default='active')

    def __str__(self):
        return f"{self.company_name} - {self.get_category_display()}"
